generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEACHER
  STUDENT
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
}

enum SubmissionType {
  TEXT
  IMAGE
  FILE
  MIXED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  nickname      String    @unique
  role          Role      @default(STUDENT)
  avatar        String?
  timezone      String?   @default("Europe/Kyiv")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherGroups      Group[]      @relation("TeacherGroups")
  teacherAssignments Assignment[] @relation("TeacherAssignments")
  teacherGrades      Grade[]      @relation("TeacherGrades")

  groupMemberships   GroupMembership[]
  submissions        Submission[]
  assignmentStudents AssignmentStudent[]

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  joinCode    String   @unique @default(cuid())
  teacherId   String
  logo        String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User              @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  memberships GroupMembership[]
  assignmentGroups AssignmentGroup[]
}

model GroupMembership {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  joinedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Assignment {
  id             String         @id @default(cuid())
  title          String
  description    String?        @db.Text
  dueDate        DateTime
  maxGrade       Int            @default(12)
  submissionType SubmissionType @default(MIXED)
  teacherId      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  teacher             User                  @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  assignmentGroups    AssignmentGroup[]
  assignmentStudents  AssignmentStudent[]
  submissions         Submission[]
  attachments         AssignmentAttachment[]
}

model AssignmentGroup {
  id           String @id @default(cuid())
  assignmentId String
  groupId      String

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, groupId])
}

model AssignmentStudent {
  id           String @id @default(cuid())
  assignmentId String
  studentId    String

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model AssignmentAttachment {
  id           String @id @default(cuid())
  assignmentId String
  fileUrl      String
  fileName     String
  fileType     String
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  textContent  String?          @db.Text
  submittedAt  DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  isLate       Boolean          @default(false)
  status       SubmissionStatus @default(SUBMITTED)

  assignment  Assignment           @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student     User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attachments SubmissionAttachment[]
  grade       Grade?

  @@unique([assignmentId, studentId])
}

model SubmissionAttachment {
  id           String @id @default(cuid())
  submissionId String
  fileUrl      String
  fileName     String
  fileType     String
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Grade {
  id           String   @id @default(cuid())
  submissionId String   @unique
  score        Int
  feedback     String?  @db.Text
  gradedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
  teacherId    String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  teacher    User       @relation("TeacherGrades", fields: [teacherId], references: [id], onDelete: Cascade)
}
